<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Dexter intentionally appears in the Dock so the operator has normal
         app-level Quit/Restart affordances without finding the launch terminal. -->
    <key>LSUIElement</key>
    <false/>

    <!-- NSMicrophoneUsageDescription: required for AVCaptureSession microphone access.
         Displayed in the system permission dialog on first launch (Phase 13). -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Dexter uses the microphone for voice interaction and speech recognition.</string>
</dict>
</plist>
