# Rust build artifacts
src/rust-core/target/

# Swift build artifacts
src/swift/.build/
src/swift/.swiftpm/

# Python
src/python-workers/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo

# macOS
.DS_Store
**/.DS_Store

# Logs and runtime sockets
*.log
*.sock

# Editor
.idea/
.vscode/
*.swp
*.swo

# Claude Code agent worktrees and local agent state. Agents that run with
# isolation: "worktree" create a full repo clone at .claude/worktrees/<name>/.
# These are ephemeral working copies, not source — they should never be tracked.
.claude/

# Local config overrides (operator-specific, never commit)
~/.dexter/

# Large model files (should never land here anyway)
*.gguf
*.bin
*.safetensors

# Repomix exports
docs/dexter-full.txt
