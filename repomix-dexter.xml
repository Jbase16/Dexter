const RECENT_HISTORY_LIMIT: usize = 25;
const SIMILARITY_REJECT_THRESHOLD: f32 = 0.60;

const HARD_REJECT_PATTERNS: &[&str] = &[
    "i'm not sure",
    "im not sure",
    "here's one",
    "heres one",
    "here is one",
