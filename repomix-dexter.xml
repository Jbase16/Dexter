    let mut trigger_action = AmbientTriggerAction::NotifyOnly;
    let mut action_limit = DEFAULT_ACTION_RECEIPT_LIMIT;
    let mut restart_component = None;
    let mut approval_policy = ApprovalPolicy::Deny;
