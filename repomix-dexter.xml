# Phase 38: dexter-cli (src/bin/dexter-cli.rs) needs the same UDS-over-gRPC
# connector pattern as the integration tests. Promoted from dev-dependencies
# so the binary can be built via `cargo build --bin dexter-cli` (release-mode).
tower      = "0.4"                                      # service_fn UDS connector for tonic Channel
hyper-util = { version = "0.1", features = ["tokio"] }  # TokioIo adapter: tokio AsyncRead/Write → hyper rt::io::Read/Write

