```rust
type StreamAudioStream = Pin<Box<dyn Stream<Item = Result<TranscriptChunk, Status>> + Send>>;

/// Phase 3 stub. Returns UNIMPLEMENTED — implemented in Phase 10 (Voice Worker Bridge).
