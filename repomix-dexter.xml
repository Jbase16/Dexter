        assert!(
            extract_facts("the weather is nice today").is_empty(),
            "no-pattern input must produce no facts"
        );
        assert!(
            extract_facts("please summarize this document").is_empty(),
            "no-pattern input must produce no facts"
        );
        assert!(
            extract_facts("").is_empty(),
            "empty input must produce no facts"
        );
    }
