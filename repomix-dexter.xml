import json
import sys

mode = sys.argv[1]
if mode == "safe":
    token = sys.argv[2]
    print(json.dumps({
        "type": "shell",
        "args": ["echo", token],
        "rationale": "ambient action smoke safe"
    }))
elif mode == "failed":
    token = sys.argv[2]
    print(json.dumps({
        "type": "shell",
        "args": ["false", token],
        "rationale": "ambient action smoke failed"
    }))
elif mode == "denied":
    path = sys.argv[2]
    print(json.dumps({
        "type": "shell",
        "args": ["rm", "-rf", path],
        "rationale": "ambient action smoke denied",
        "category_override": "destructive"
    }))
else:
    raise SystemExit(f"unknown mode: {mode}")
PY
}

