    DATETIME_PATTERNS.iter().any(|p| s.contains(p))
        || VERSION_PATTERNS.iter().any(|p| s.contains(p))
        || PERSON_STATUS_PATTERNS.iter().any(|p| s.contains(p))
        || NEWS_PATTERNS.iter().any(|p| s.contains(p))
}

