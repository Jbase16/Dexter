}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum HumorMechanism {
    Misdirection,
    AbsurdSpecificity,
    HostileUnderstatement,
    DarkEscalation,
    FalseAuthority,
    Literalism,
}

impl HumorMechanism {
    pub fn as_str(self) -> &'static str {
        match self {
