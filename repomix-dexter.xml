    fn blend(a: usize, b: usize, wa: f32, wb: f32) -> Vec<f32> {
        let mut v = vec![0.0f32; RETRIEVAL_EMBED_DIM];
        v[a] = wa;
        v[b] = wb;
        let norm = (wa * wa + wb * wb).sqrt();
        v.iter_mut().for_each(|x| *x /= norm);
