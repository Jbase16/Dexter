    "$CLI_BIN" --auto-deny --idle-timeout 180 "$@" > "$out_file" 2>&1
}

run_cli_verbose_approve() {
    local out_file="$1"
    shift
    : > "$out_file"
    "$CLI_BIN" --auto-approve --idle-timeout 180 "$@" > "$out_file" 2>&1
}

json_string() {
    python3 - "$1" <<'PY'
import json
import sys

print(json.dumps(sys.argv[1]))
PY
}

run_cli_action_sequence() {
    local out_file="$1"
    shift
