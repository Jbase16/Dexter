                "thoroughly analyze",
                "in-depth analysis",
            ],
        ) {
            return Complexity::DEEP;
        }












        if contains_any(
            &lower,
            &["from scratch", "compare and contrast", "full system"],
        ) {
            score = score.saturating_add(2);
        }









        if contains_any(
            &lower,
