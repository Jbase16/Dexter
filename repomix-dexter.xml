wait_for_swift_launch() {
    local waited=0
    while [[ "$waited" -lt 180 ]]; do
        if grep -Fq "cd src/swift && swift run" "$LOG" ||
           grep -Fq "[DexterClient] Ping OK" "$LOG"; then
            return 0
        fi
        if [[ -n "$RUN_PID" ]] && ! kill -0 "$RUN_PID" >/dev/null 2>&1; then
