PASS="PASS"
FAIL="FAIL"
INFO="INFO"

if [[ "${1:-}" == "--start-core" ]]; then
    START_CORE=1
    shift
fi

if [[ "${1:-}" != "" ]]; then
    LOG="$1"
fi

say() {
